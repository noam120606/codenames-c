{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "codenames-c: Run Server",
      "type": "shell",
      "command": "./run.sh",
      "options": {
        "cwd": "${workspaceFolder}/server"
      },
      "presentation": {
        "panel": "shared",
        "group": "dev",
        "clear": false
      }
    },
    {
      "label": "codenames-c: Run Client",
      "type": "shell",
      "command": "./run.sh",
      "options": {
        "cwd": "${workspaceFolder}/client"
      },
      "presentation": {
        "panel": "shared",
        "group": "dev",
        "clear": false
      }
    },
    {
      "label": "codenames-c: Run Client with params",
      "type": "shell",
      "command": "./run_with_params.sh",
      "options": {
        "cwd": "${workspaceFolder}/client"
      },
      "presentation": {
        "panel": "shared",
        "group": "dev",
        "clear": false
      }
    },
    {
      "label": "codenames-c: Run Both",
      "dependsOn": ["codenames-c: Run Server", "codenames-c: Run Client"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "codenames-c: Run Both with params",
      "dependsOn": ["codenames-c: Run Server", "codenames-c: Run Client with params"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
  ]
}
